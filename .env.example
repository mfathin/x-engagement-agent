# ============================================
# X Engagement Agent — Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- TELEGRAM CONFIG ---
TELEGRAM_BOT_TOKEN=<YOUR_BOT_TOKEN>
TELEGRAM_CHAT_ID=<YOUR_CHAT_ID>
# URL for webhook (e.g. ngrok url during dev)
TELEGRAM_WEBHOOK_URL=https://your-tunnel-url.loca.lt/api/telegram/webhook

# --- AI PROVIDERS ---

# Gemini (Primary)
GEMINI_ENABLED=true
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.5-flash

# Token Router (Fallback)
TOKEN_ROUTER_ENABLED=true
TOKEN_ROUTER_URL=https://api.tokenrouter.com/v1
TOKEN_ROUTER_API_KEY=your_token_router_key
TOKEN_ROUTER_MODEL=minimax-m3

# Omniroute (New Fallback)
OMNIROUTE_ENABLED=false
OMNIROUTE_URL=https://openrouter.ai/api/v1
OMNIROUTE_API_KEY=your_omniroute_key
OMNIROUTE_MODEL=openai/gpt-5.3-codex

# --- ENGAGEMENT CONFIG ---
# Comma-separated search queries for tweet discovery
ENGAGEMENT_QUERIES=meme,indonesian news,news,comedy,AI,startups,tech

# Minimum engagement thresholds for a tweet to be considered
ENGAGEMENT_MIN_LIKES=300
ENGAGEMENT_MIN_REPLIES=20

# Author follower range (skip very small or very large accounts)
ENGAGEMENT_MIN_FOLLOWERS=500
ENGAGEMENT_MAX_FOLLOWERS=500000

# Maximum tweet age in hours
TWEET_MAX_AGE_HOURS=4

# --- NOTIFICATIONS ---
# Enable reading from the notifications page (bell icon)
NOTIFICATIONS_ENABLED=true
NOTIFICATIONS_CHECK_INTERVAL=10

# --- AUTO POST ---
# Enable auto-posting engaging tweets
AUTO_POST_ENABLED=false
AUTO_POST_INTERVAL_MINUTES=290

# --- RATE LIMITING ---
# Maximum replies per hour
MAX_REPLIES_PER_HOUR=3

# Active hours (24h format, tool is inactive outside this range)
ACTIVE_HOURS_START=7
ACTIVE_HOURS_END=23

# --- AI BUDGET ---
AI_DAILY_BUDGET=5.00
AI_MONTHLY_BUDGET=100.00

# --- BROWSER ---
# Path to store persistent browser session data
BROWSER_DATA_DIR=browser_data
# Browser viewport
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=900

# --- LOGGING ---
LOG_DIR=logs
LOG_LEVEL=INFO
